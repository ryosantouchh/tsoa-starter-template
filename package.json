{
  "name": "tsoa-starter-template",
  "version": "1.0.0",
  "main": "dist/entry/api/app.js",
  "author": "ryosantouchh <kittitat.suntimak@gmail.com>",
  "license": "MIT",
  "scripts": {
    "tsoa": "./node_modules/.bin/tsoa",
    "dev": "npm run nodemon -- -x \"npm run swagger && ts-node -r tsconfig-paths/register ./src/entry/api/app.ts\"",
    "nodemon": "./node_modules/.bin/nodemon",
    "swagger": "npm run tsoa spec-and-routes",
    "db:up": "./sh/db-up.sh",
    "migrate:only": "node --env-file=.env --import tsx ./src/infra/database/migrate.ts",
    "migrate:type": "kysely-codegen --out-file ./src/infra/database/types.ts",
    "migrate": "npm run migrate:only && npm run migrate:type"
  },
  "dependencies": {
    "@tsoa/runtime": "^7.0.0-alpha.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "kysely": "^0.28.15",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "kysely-codegen": "^0.20.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
