{
  "entryFile": "src/entry/api/app.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/entry/api/controllers/**/*.controller.ts"],
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@controller/*": ["entry/api/controllers/*"],
      "@domain/*": ["core/domain/*"],
      "@entities/*": ["core/entities/*"],
      "@repositories/*": ["core/repositories/*"],
      "@infra/*": ["infra/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "spec": {
    "outputDirectory": "./src",
    "specVersion": 3,
    "basePath": "/api"
  },
  "routes": {
    "routesDir": "./src/entry/api/",
    "middleware": "express",
    "iocModule": "src/container.ts"
  }
}
